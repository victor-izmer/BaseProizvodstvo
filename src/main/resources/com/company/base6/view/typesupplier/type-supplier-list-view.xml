<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://typeSupplierListView.title"
      focusComponent="typeSuppliersDataGrid">
    <data>
        <collection id="typeSuppliersDc"
                    class="com.company.base6.entity.TypeSupplier">
            <fetchPlan extends="_base"/>
            <loader id="typeSuppliersDl" readOnly="true">
                <query>
                    <![CDATA[select e from TypeSupplier e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="typeSuppliersDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <button id="createButton" action="typeSuppliersDataGrid.create"/>
            <button id="editButton" action="typeSuppliersDataGrid.edit"/>
            <button id="removeButton" action="typeSuppliersDataGrid.remove"/>
            <simplePagination id="pagination" dataLoader="typeSuppliersDl"/>
        </hbox>
        <dataGrid id="typeSuppliersDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="typeSuppliersDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="create" type="list_create"/>
                <action id="edit" type="list_edit"/>
                <action id="remove" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="description"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
