<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://basketListView.title"
      focusComponent="basketsDataGrid">
    <data>
        <collection id="basketsDc"
                    class="com.company.base6.entity.Basket">
            <fetchPlan extends="_base">
                <property name="requestRef" fetchPlan="_base">
                    <property name="supplierRef" fetch="AUTO" fetchPlan="_base"/>
                    <property name="statusZayavkaRef" fetchPlan="_base"/>
                </property>
                <property name="detalRef" fetchPlan="_base">
                    <property name="materialref" fetchPlan="_base"/>
                    <property name="parametrsizeref" fetchPlan="_base"/>
                    <property name="typeref" fetchPlan="_base"/>
                    <property name="fullPhotoPath"/>
                    <property name="fullDrawPath"/>
                </property>
                <property name="operationRef" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="basketsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Basket e]]>
                </query>
            </loader>
        </collection>
        <instance id="basketDc"
                  class="com.company.base6.entity.Basket">
            <fetchPlan extends="_base">
                <property name="requestRef" fetchPlan="_base">
                    <property name="supplierRef" fetch="AUTO" fetchPlan="_base"/>
                    <property name="statusZayavkaRef" fetchPlan="_base"/>
                </property>
                <property name="detalRef" fetchPlan="_base">
                    <property name="materialref" fetchPlan="_base"/>
                    <property name="parametrsizeref" fetchPlan="_base"/>
                    <property name="typeref" fetchPlan="_base"/>
                    <property name="fullPhotoPath"/>
                    <property name="fullDrawPath"/>
                </property>
                <property name="operationRef" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="basketDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout padding="false">
        <formLayout id="layoutWrapper" classNames="master-detail-layout" height="100%">
            <vbox id="listLayout" height="100%">
                <genericFilter id="genericFilter"
                               dataLoader="basketsDl">
                    <properties include=".*"/>
                </genericFilter>
                <hbox id="buttonsPanel" classNames="buttons-panel">
                    <button id="createButton" action="basketsDataGrid.create"/>
                    <button id="editButton" action="basketsDataGrid.edit"/>
                    <button id="removeButton" action="basketsDataGrid.remove"/>
                    <simplePagination id="pagination" dataLoader="basketsDl"/>
                </hbox>
                <dataGrid id="basketsDataGrid"
                          width="100%"
                          minHeight="20em"
                          dataContainer="basketsDc"
                          columnReorderingAllowed="true">
                    <actions>
                        <action id="create" type="list_create"/>
                        <action id="edit" type="list_edit"/>
                        <action id="remove" type="list_remove"/>
                    </actions>
                    <columns resizable="true">
                        <column property="id"/>
                        <column property="requestRef"/>
                        <column property="detalRef"/>
                        <column property="operationRef"/>
                        <column property="quantity"/>
                        <column property="price"/>
                        <column property="nds"/>
                        <column property="materialOwner"/>
                        <column property="primBasket"/>
                    </columns>
                </dataGrid>
                <hbox id="lookupActions" visible="false">
                    <button id="selectButton" action="selectAction"/>
                    <button id="discardButton" action="discardAction"/>
                </hbox>
            </vbox>
            <vbox id="detailsLayout" height="100%">
                <formLayout id="form" dataContainer="basketDc">
                    <responsiveSteps>
                        <responsiveStep minWidth="0" columns="1"/>
                        <responsiveStep minWidth="40em" columns="2"/>
                    </responsiveSteps>
                    <textField id="idField" property="id"/>
                    <entityPicker id="requestRefField" property="requestRef">
                        <actions>
                            <action id="entityLookup" type="entity_lookup"/>
                            <action id="entityClear" type="entity_clear"/>
                        </actions>
                    </entityPicker>
                    <entityPicker id="detalRefField" property="detalRef">
                        <actions>
                            <action id="entityLookup" type="entity_lookup"/>
                            <action id="entityClear" type="entity_clear"/>
                        </actions>
                    </entityPicker>
                    <entityPicker id="operationRefField" property="operationRef">
                        <actions>
                            <action id="entityLookup" type="entity_lookup"/>
                            <action id="entityClear" type="entity_clear"/>
                        </actions>
                    </entityPicker>
                    <textField id="quantityField" property="quantity"/>
                    <textField id="priceField" property="price"/>
                    <checkbox id="ndsField" property="nds"/>
                    <checkbox id="materialOwnerField" property="materialOwner"/>
                    <textField id="primBasketField" property="primBasket"/>
                </formLayout>
                <hbox id="detailActions">
                    <button id="saveButton" text="msg:///actions.Save" icon="CHECK" themeNames="primary"/>
                    <button id="cancelButton" text="msg:///actions.Cancel" icon="BAN"/>
                </hbox>
            </vbox>
        </formLayout>
    </layout>
</view>
