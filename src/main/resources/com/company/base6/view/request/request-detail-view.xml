<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://requestDetailView.title"
      focusComponent="form">
    <data>
        <instance id="requestDc"
                  class="com.company.base6.entity.Request">
            <fetchPlan extends="_base">
                <property name="basketRef" fetchPlan="_base">
                    <property name="operationRef" fetchPlan="_instance_name">
                        <property name="detailOut" fetchPlan="_base"/>
                    </property>
                </property>
            </fetchPlan>
            <loader id="requestDl"/>
            <collection id="basketRefDc" property="basketRef"/>
        </instance>
        <collection id="suppliersDc" class="com.company.base6.entity.Supplier">
            <loader id="suppliersDl" readOnly="true">
                <query>
                    <![CDATA[select e from Supplier e order by e.description asc]]>
                </query>
            </loader>
            <fetchPlan extends="_base"/>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <settings auto="true"/>
    </facets>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="requestDc" height="40em">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>
            <vbox>
                <hbox>
                    <entityComboBox id="supplierRefField"
                                    property="supplierRef"
                                    dataContainer="requestDc" itemsContainer="suppliersDc" width="70%" minWidth="25em"
                                    label="Поставщик" alignSelf="STRETCH"/>
                    <textField id="sumRequestField" property="sumRequest" maxWidth="15%" minWidth="10em" width="15%"
                               label="Сумма заказа"/>
                </hbox>
                <hbox id="Dates">
                    <datePicker id="dataRequestField" property="dateRequest" label="Дата заказа"/>
                    <datePicker id="dateControlField" property="dateControl" label="Дата контроля"/>
                    <datePicker id="dateFinishField" property="dateFinish" label="Дата завершения"/>
                </hbox>
                <textField id="scanInvoiceField" property="scanInvoice" alignSelf="STRETCH" label="Скан счета"/>
                <button id="ViewFile" minHeight="5em" minWidth="5em" text="Привет!"
                        icon="vaadin:airplane" themeNames="large"/>
                <textArea id="primRequestField" property="primRequest" height="6em" alignSelf="STRETCH" label="Примечания запроса"/>
            </vbox>
            <vbox id="SpisokDetal" minWidth="50em">
                <hbox id="buttonsPanel" >
                    <button action="basketRefDataGrid.createAction"/>
                    <button action="basketRefDataGrid.editAction"/>
                    <button action="basketRefDataGrid.removeAction"/>
                </hbox>
                <dataGrid id="basketRefDataGrid"
                          dataContainer="basketRefDc"
                          width="100%" height="100%" minHeight="25em">
                    <actions>
                        <action id="createAction" type="list_create">
                            <properties>
                                <property name="openMode" value="DIALOG"/>
                            </properties>
                        </action>
                        <action id="editAction" type="list_edit">
                            <properties>
                                <property name="openMode" value="DIALOG"/>
                            </properties>
                        </action>
                        <action id="removeAction" type="list_remove"/>
                    </actions>
                    <columns>
                        <column property="operationRef.detailOut" resizable="true" sortable="false"/>
                        <column property="quantity" resizable="true" sortable="false"/>
                        <column property="price" resizable="true" sortable="false"/>
                        <column property="nds" resizable="true" sortable="false"/>
                        <column property="primBasket" resizable="true" sortable="false"/>
                    </columns>
                </dataGrid>

            </vbox>
            <vbox>
                <iframe id="pdfFrame" width="100%" height="100%" resource="test.pdf" alignSelf="STRETCH"/>
            </vbox>

        </formLayout>

        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
