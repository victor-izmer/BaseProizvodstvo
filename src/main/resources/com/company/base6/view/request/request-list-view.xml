<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition" xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
      title="msg://requestListView.title"
      focusComponent="requestsDataGrid">
    <data>
        <collection id="requestsDc"
                    class="com.company.base6.entity.Request">
            <fetchPlan extends="_base">
                <property name="supplierRef" fetch="AUTO" fetchPlan="_base"/>
                <property name="statusZayavkaRef" fetch="AUTO" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="requestsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Request e ORDER BY e.dateRequest]]>
                </query>
            </loader>
        </collection>


        <collection id="basketsDc"
                    class="com.company.base6.entity.Basket">
            <fetchPlan extends="_base">
                <property name="detalRef" fetch="AUTO" fetchPlan="_base"/>
                <property name="unitmeasureRef" fetch="AUTO" fetchPlan="_base"/>
                <property name="requestRef" fetch="AUTO" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="basketsDl">
                <query>
                    <![CDATA[
                        select b from Basket b
                        WHERE b.requestRef.id = :requestId]]>
                </query>
            </loader>
        </collection>


        <instance id="requestDc"
                  class="com.company.base6.entity.Request">
            <fetchPlan extends="_base">
                <property name="supplierRef" fetch="AUTO" fetchPlan="_base"/>
                <property name="statusZayavkaRef" fetch="AUTO" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="requestDl"/>
        </instance>

        <instance id="workpieceDc"
                  class="com.company.base6.Workpiece">
            <fetchPlan extends="_base">
                <property name="materialref" fetch="AUTO" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="workpieceDl">
                <query><![CDATA[select w from Workpiece w where w.id = :workpieceId]]></query>
            </loader>
        </instance>

    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <settings auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout padding="false">
        <formLayout id="layoutWrapper" classNames="master-detail-layout" height="100%">
            <vbox id="listLayout" height="100%">
                <genericFilter id="genericFilter"
                               dataLoader="requestsDl">
                    <properties include=".*"/>
                </genericFilter>
                <hbox id="buttonsPanel" classNames="buttons-panel">
                    <button id="createButton" action="requestsDataGrid.create"/>
                    <button id="editButton" action="requestsDataGrid.edit"/>
                    <button id="removeButton" action="requestsDataGrid.remove"/>
                    <simplePagination id="pagination" dataLoader="requestsDl"/>
                </hbox>
                <dataGrid id="requestsDataGrid"
                          width="100%"
                          minHeight="20em"
                          dataContainer="requestsDc"
                          columnReorderingAllowed="true" pageSize="25">
                    <actions>
                        <action id="create" type="list_create"/>
                        <action id="edit" type="list_edit"/>
                        <action id="remove" type="list_remove"/>
                    </actions>
                    <columns resizable="true">
                        <column property="supplierRef" width="130px"/>
                        <column property="dateRequest" width="70px"/>
                        <column property="scanInvoice" textAlign="END" width="120px"/>
                        <column property="dateControl" width="70px"/>
                        <column property="primRequest" width="150px"/>
                        <column property="statusZayavkaRef" width="40px"/>
                        <column property="sumRequest" width="40px"/>
                    </columns>

                </dataGrid>


                <!-- Список корзин -->
                <dataGrid id="basketsDataGrid"
                          width="100%"
                          minHeight="15em"
                          dataContainer="basketsDc"
                          detailsVisibleOnClick="true">
                    <columns>
                        <column property="detalRef.наименование"/>
                        <column property="quantity"/>
                        <column property="unitmeasureRef.description"/>
                    </columns>


                </dataGrid>

                <!-- Детали Workpiece -->
                <vbox id="workpieceDetails" visible="{workpieceDc.item != null}" spacing="true">
                    <h4 text="Детали изделия"/>
                    <textField id="materialField"
                               value="{workpieceDc.item.materialref.name}"
                               label="Материал"
                               readOnly="true"/>
                    <textField id="sizeField"
                               value="{workpieceDc.item.размер}"
                               label="Размер"
                               readOnly="true"/>
                    <image id="photoImage"
                           width="200px"
                           height="200px"
                           />
                </vbox>


                <hbox id="lookupActions" visible="false">
                    <button id="selectButton" action="selectAction"/>
                    <button id="discardButton" action="discardAction"/>
                </hbox>
            </vbox>
            <vbox id="detailsLayout" height="100%">
                <formLayout id="form" dataContainer="requestDc">
                    <responsiveSteps>
                        <responsiveStep minWidth="0" columns="1"/>
                        <responsiveStep minWidth="40em" columns="2"/>
                    </responsiveSteps>
                    <entityPicker id="supplierRefField" property="supplierRef">
                        <actions>
                            <action id="entityLookup" type="entity_lookup"/>
                            <action id="entityClear" type="entity_clear"/>
                        </actions>
                    </entityPicker>
                    <entityPicker id="statusZayavkaRefField" property="statusZayavkaRef" maxWidth="130px">
                        <actions>
                            <action id="entityLookup" type="entity_lookup"/>
                            <action id="entityClear" type="entity_clear"/>
                        </actions>
                    </entityPicker>
                    <textField id="sumRequestField" property="sumRequest" maxWidth="130px"/>
                    <datePicker id="dateRequestField" property="dateRequest" maxWidth="130px"/>
                    <datePicker id="dateControlField" property="dateControl" maxWidth="130px"/>
                    <datePicker id="dateFinishField" property="dateFinish" maxWidth="130px"/>
                    <textField id="primRequestField" property="primRequest"/>
                    <textField id="scanInvoiceField" property="scanInvoice" alignSelf="END" css=" direction: rtl;"/>

                </formLayout>
                <hbox id="detailActions">
                    <button id="saveButton" text="msg:///actions.Save" icon="CHECK" themeNames="primary"/>
                    <button id="cancelButton" text="msg:///actions.Cancel" icon="BAN"/>
                </hbox>
            </vbox>
        </formLayout>
    </layout>
</view>
