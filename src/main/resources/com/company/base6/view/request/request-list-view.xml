<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://requestListView.title"
      focusComponent="requestsDataGrid">
    <data>
        <collection id="requestsDc"
                    class="com.company.base6.entity.Request">
            <fetchPlan extends="_base">
            </fetchPlan>
            <loader id="requestsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Request e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <button id="button" text="Проверка сроков"/>
        <button id="CountSum" text="Сумма"/>
        <genericFilter id="genericFilter"
                       dataLoader="requestsDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <button id="createButton" action="requestsDataGrid.createAction"/>
            <button id="editButton" action="requestsDataGrid.editAction"/>
            <button id="removeButton" action="requestsDataGrid.removeAction"/>
            <simplePagination id="pagination" dataLoader="requestsDl" itemsPerPageDefaultValue="20"/>
        </hbox>
        <dataGrid id="requestsDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="requestsDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create">
                    <properties>
                        <property name="openMode" value="DIALOG"/>
                    </properties>
                </action>
                <action id="editAction" type="list_edit">
                    <properties>
                        <property name="openMode" value="DIALOG"/>
                    </properties>
                </action>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">

                <column property="numInvoice"/>
                <column property="dateRequest"/>
                <column property="scanInvoice" textAlign="END" key="scan"/>
                <column property="dateControl"/>
                <column property="dateFinish"/>
                <column property="primRequest"/>
                <column property="sumRequest"/>
                <column property="supplierRef"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
