<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://operationDetailView.title"
      focusComponent="form">
    <data>
        <instance id="operationDc"
                  class="com.company.base6.entity.Operation">
            <fetchPlan extends="_base">
                <property name="typeOperationRef" fetch="AUTO" fetchPlan="_base"/>
                <property name="detailOut" fetch="AUTO" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="operationDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="operationDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>
            <entityPicker id="typeOperationRefField" property="typeOperationRef">
                <actions>
                    <action id="entityLookup" type="entity_lookup"/>
                    <action id="entityClear" type="entity_clear"/>
                </actions>
            </entityPicker>
            <entityPicker id="detailOutField" property="detailOut">
                <actions>
                    <action id="entityLookup" type="entity_lookup"/>
                    <action id="entityClear" type="entity_clear"/>
                </actions>
            </entityPicker>
            <textField id="priceOpField" property="priceOp"/>
            <checkbox id="ndsField" property="nds"/>
            <textField id="primOpField" property="primOp"/>
            <textField id="durationOpField" property="durationOp"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
