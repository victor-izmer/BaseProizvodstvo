<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://statusZayavkaListView.title"
      focusComponent="statusZayavkasDataGrid">
    <data>
        <collection id="statusZayavkasDc"
                    class="com.company.base6.entity.StatusZayavka">
            <fetchPlan extends="_base"/>
            <loader id="statusZayavkasDl" readOnly="true">
                <query>
                    <![CDATA[select e from StatusZayavka e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="statusZayavkasDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <button id="createButton" action="statusZayavkasDataGrid.create"/>
            <button id="editButton" action="statusZayavkasDataGrid.edit"/>
            <button id="removeButton" action="statusZayavkasDataGrid.remove"/>
            <simplePagination id="pagination" dataLoader="statusZayavkasDl"/>
        </hbox>
        <dataGrid id="statusZayavkasDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="statusZayavkasDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="create" type="list_create"/>
                <action id="edit" type="list_edit"/>
                <action id="remove" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="description"/>
                <column property="color"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
