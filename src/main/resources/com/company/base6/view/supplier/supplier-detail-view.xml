<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://supplierDetailView.title"
      focusComponent="form">
    <data>
        <instance id="supplierDc"
                  class="com.company.base6.entity.Supplier">
            <fetchPlan extends="_base">
                <property name="typeSupplierRef" fetch="AUTO" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="supplierDl"/>
        </instance>
        <collection id="typeSuppliersDc" class="com.company.base6.entity.TypeSupplier">
            <fetchPlan extends="_base"/>
            <loader id="typeSuppliersDl" readOnly="true">
                <query>
                    <![CDATA[select e from TypeSupplier e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="supplierDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>
            <textField id="descriptionField" property="description" maxWidth="25em"/>
            <entityComboBox id="typeSuppliersComboBox"
                            itemsContainer="typeSuppliersDc"
                            dataContainer="supplierDc"
                            property="typeSupplierRef" maxWidth="20em"/>
            <textField id="whatDoField" property="whatDo"/>
            <textArea id="contactField" property="contact" minRows="4"/>
            <textArea id="primSupplierField" property="primSupplier" minRows="4"/>
            <textArea id="textRequestField" property="textRequest" minRows="4"/>
            <textField id="pathFilesField" property="pathFiles"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
