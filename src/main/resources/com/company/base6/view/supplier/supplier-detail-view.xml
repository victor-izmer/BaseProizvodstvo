<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://supplierDetailView.title"
      focusComponent="form">
    <data>
        <instance id="supplierDc"
                  class="com.company.base6.entity.Supplier">
            <fetchPlan extends="_base">
                <property name="typeSupplierRef" fetch="AUTO" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="supplierDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
    </facets>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="supplierDc">
            <responsiveSteps>
                <responsiveStep minWidth="0" columns="1"/>
                <responsiveStep minWidth="40em" columns="2"/>
            </responsiveSteps>
            <textField id="descriptionField" property="description"/>
            <textField id="whatDoField" property="whatDo"/>
            <entityPicker id="typeSupplierRefField" property="typeSupplierRef">
                <actions>
                    <action id="entityLookup" type="entity_lookup"/>
                    <action id="entityClear" type="entity_clear"/>
                </actions>
            </entityPicker>
            <textField id="contactField" property="contact"/>
            <textField id="primSupplierField" property="primSupplier"/>
            <textField id="textRequestField" property="textRequest"/>
            <textField id="pathFilesField" property="pathFiles"/>
        </formLayout>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
