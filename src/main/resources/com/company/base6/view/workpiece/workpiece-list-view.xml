<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://workpieceListView.title"
      focusComponent="workpiecesDataGrid">
    <data>
        <instance id="workpieceDc"
                  class="com.company.base6.entity.Workpiece">
            <fetchPlan extends="_base">
                <property name="operationRef" fetchPlan="_base"/>
                <property name="typeref" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="workpieceDl"/>
        </instance>
        <collection id="workpiecesDc"
                    class="com.company.base6.entity.Workpiece">
            <fetchPlan extends="_base">
                <property name="parametrsizeref" fetchPlan="_base"/>
                <property name="typeref" fetchPlan="_base"/>

            </fetchPlan>
            <loader id="workpiecesDl" readOnly="true">
                <query>
                    <![CDATA[select e from Workpiece e order by e.description asc]]>
                </query>
            </loader>
        </collection>
        <collection id="specificationsDc" class="com.company.base6.entity.Specification">
            <loader id="specificationsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Specification e]]>
                </query>
            </loader>
            <fetchPlan extends="_base"/>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="workpiecesDl">
            <properties include=".*"/>
        </genericFilter>
        <formLayout id="form" dataContainer="workpiecesDc">
            <vbox>
                <treeDataGrid id="specificationsDataGrid"
                              dataContainer="specificationsDc"
                              hierarchyProperty="parentref"
                              columnReorderingAllowed="true" showOrphans="true" themeNames="compact"
                              allRowsVisible="true">
                    <actions>
                        <action id="create" type="list_create"/>
                        <action id="edit" type="list_edit"/>
                        <action id="remove" type="list_remove"/>
                    </actions>
                    <columns resizable="true">
                        <column property="detalref.fullDescription" />
                        <column property="fullSkolko" textAlign="CENTER" sortable="false"/>
                        <column property="primSpec" />
                        <column property="id"/>
                    </columns>
                </treeDataGrid>
            </vbox>
            <vbox id="listLayout">
                <hbox id="buttonsPanel" classNames="buttons-panel">
                    <button id="createButton" action="workpiecesDataGrid.create"/>
                    <button id="editButton" action="workpiecesDataGrid.edit"/>
                    <button id="removeButton" action="workpiecesDataGrid.remove"/>
                    <simplePagination id="pagination" dataLoader="workpiecesDl"/>
                </hbox>
                <dataGrid id="workpiecesDataGrid"
                          minHeight="20em"
                          dataContainer="workpiecesDc"
                          columnReorderingAllowed="true" themeNames="compact">
                    <actions>
                        <action id="create" type="list_create">
                            <properties>
                                <property name="openMode" value="DIALOG"/>
                            </properties>
                        </action>
                        <action id="edit" type="list_edit">
                            <properties>
                                <property name="openMode" value="DIALOG"/>
                            </properties>
                        </action>
                        <action id="remove" type="list_remove"/>
                    </actions>
                    <columns resizable="true">
                        <column property="fullDescription"/>
                        <column property="primDetal"/>
                        <column property="priceLast"/>
                        <column property="priceLastNDS"/>
                    </columns>
                </dataGrid>
            </vbox>
        </formLayout>
        <hbox id="detailActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
