<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://specificationListView.title"
      focusComponent="specificationsDataGrid">
    <data>
        <collection id="specificationsDc"
                    class="com.company.base6.entity.Specification">
            <fetchPlan extends="_base">
                <property fetchPlan="_base" name="detalref">
                    <property name="description"/>
                    <property name="photoPath"/>
                </property>
                <property fetchPlan="_base" name="parentref">
                    <property fetchPlan="_base" name="detalref"/>
                </property>
                <property fetchPlan="_base" name="unitMeasure"/>
                <property name="id"/>
            </fetchPlan>
            <loader id="specificationsDl" readOnly="true" cacheable="true">
                <query>
                    <![CDATA[select e from Specification e ORDER BY e.id]]>
                </query>
            </loader>
        </collection>
        <instance id="specificationDc"
                  class="com.company.base6.entity.Specification">
            <fetchPlan extends="_base">
                <property fetchPlan="_base" name="detalref"/>
                <property fetchPlan="_base" name="parentref"/>
                <property fetchPlan="_base" name="unitMeasure"/>
            </fetchPlan>
            <loader id="specificationDl"/>
        </instance>
        <collection id="specificationDetalDc" class="com.company.base6.entity.Specification">
            <fetchPlan extends="_base">
                <property name="parentref" fetchPlan="_base"/>
                <property name="detalref" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="specificationDetalDl" readOnly="true">
                <query>
                    <![CDATA[select e from Specification e where e.parentref.id = :detal]]>
                </query>
            </loader>
        </collection>

    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <settings auto="true"/>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout padding="false">
        <formLayout id="layoutWrapper" classNames="master-detail-layout" height="100%">
            <vbox id="listLayout" height="100%" width="40%" maxWidth="40%">
                <genericFilter id="genericFilter"
                               dataLoader="specificationsDl">
                    <properties include=".*"/>
                </genericFilter>

                <treeDataGrid id="specificationsDataGrid"
                              width="100%"
                              minHeight="20em"
                              dataContainer="specificationsDc"
                              hierarchyProperty="parentref"
                              columnReorderingAllowed="true" showOrphans="true" >
                    <actions>
                        <action id="create" type="list_create"/>
                        <action id="edit" type="list_edit">
                            <properties>
                                <property name="openMode" value="DIALOG"/>
                            </properties>
                        </action>
                        <action id="remove" type="list_remove"/>
                    </actions>
                    <columns resizable="true">
                        <column property="detalref.description" width="310px"/>
                        <column property="skolko" width="50px" textAlign="CENTER"/>
                        <column property="unitMeasure" width="40px" textAlign="CENTER"/>
                        <column property="primSpec" autoWidth="true"/>
                        <column property="id"/>

                    </columns>
                </treeDataGrid>

                <hbox id="lookupActions" visible="false">
                    <button id="selectButton" action="selectAction"/>
                    <button id="discardButton" action="discardAction"/>
                </hbox>
            </vbox>
            <vbox id="detailsLayout" height="100%">
                <hbox id="buttonsPanelchild" classNames="buttons-panel">
                    <button id="createButtonchild" action="childSpecification.create"/>
                    <button id="editButtonchild" action="childSpecification.edit"/>
                    <button id="removeButtonchild" action="childSpecification.remove"/>
                </hbox>
                <dataGrid id="childSpecification"
                          dataContainer="specificationDetalDc"
                          minHeight="35rem"
                          aggregationPosition="TOP"
                          columnReorderingAllowed="true">
                    <actions>
                        <action id="create" type="list_create">
                            <properties>
                                <property name="openMode" value="DIALOG"/>
                            </properties>
                        </action>
                        <action id="edit" type="list_edit">
                            <properties>
                                <property name="openMode" value="DIALOG"/>
                            </properties>
                        </action>
                        <action id="remove" type="list_remove"/>
                    </actions>
                    <columns resizable="true">
                        <column property="detalref"/>
                        <column property="skolko"/>
                        <column property="detalref.typeref"/>
                        <column property="unitMeasure"/>
                        <column property="primSpec"/>
                        <column property="detalref.timeProduce"/>
                        <column property="detalref.priceLast"/>
                        <column property="detalref.priceLastNDS"/>
                    </columns>
                </dataGrid>
                <formLayout id="form" dataContainer="specificationDetalDc">

                    <responsiveSteps>
                        <responsiveStep minWidth="0" columns="1"/>
                        <responsiveStep minWidth="40em" columns="2"/>
                    </responsiveSteps>

                <hbox>
                    <image
                            id="photoImage" classNames="photo-preview"
                            resource="{detalref.photoId}" text="msg://image.text"
                            css=" height:300px; width:auto!important;object-fit: contain; max-width: 300px;"
                            dataContainer="specificationDetalDc" property="detalref.photoId"/>
                    <image
                            id="drawImage" classNames="photo-preview"
                            resource="{detalref.drawId}" text="msg://image.text"
                            css=" height:300px; width:auto!important;object-fit: contain; max-width: 300px;"
                            dataContainer="specificationDetalDc" property="detalref.drawId" minWidth="40em"/>
                    <textArea property="detalref.primDetal" label="Примечание детали" minWidth="40em"/>
                </hbox>
                    <div>
                        <iframe id="pdfFrame" width="100%" height="100%" alignSelf="STRETCH"
                                resource="detalRef.getFullPhotoPath"/>
                    </div>
                <div>
                    <textField id="materialrefField" property="detalref.materialref.description" label="Материал"/>
                    <textField id="параметрРазмераField" property="detalref.parametrsizeref" maxWidth="110px"/>
                    <textField id="размерField" property="detalref.size" maxWidth="70px"/>
                    <textField id="времяИзготовленияField" property="detalref.timeProduce" maxWidth="100px"/>
                </div>
                    <textArea id="primSpecField" height="9.5em" property="primSpec"/>

                </formLayout>
                <hbox id="detailActions">
                    <button id="saveButton" text="msg:///actions.Save" icon="CHECK" themeNames="primary"/>
                    <button id="cancelButton" text="msg:///actions.Cancel" icon="BAN"/>
                </hbox>
            </vbox>
        </formLayout>
    </layout>
</view>
