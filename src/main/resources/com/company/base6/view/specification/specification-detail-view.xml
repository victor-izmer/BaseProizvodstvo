<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      title="msg://specificationDetailView.title"
      focusComponent="form">
    <data>
        <instance id="specificationDc"
                  class="com.company.base6.entity.Specification">
            <fetchPlan extends="_base">
                <property name="detalref" fetchPlan="_base"/>
                <property name="parentref" fetchPlan="_base">
                    <property name="detalref" fetchPlan="_base"/>
                </property>
                <property name="unitMeasure" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="specificationDl"/>
        </instance>
        <collection id="workpiecesDc" class="com.company.base6.entity.Workpiece">
            <fetchPlan extends="_base">
                <property name="materialref" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="workpiecesDl" readOnly="true">
                <query>
                    <![CDATA[select e from Workpiece e order by e.description asc]]>
                </query>
            </loader>
        </collection>
        <collection id="operationsDc" class="com.company.base6.entity.Operation">
            <fetchPlan extends="_base"/>
            <loader id="operationsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Operation e where e.detailOut = :container_workpiecesDc]]>
                </query>
            </loader>
        </collection>

        <collection id="unitMeasuresDc" class="com.company.base6.entity.UnitMeasure">
            <loader id="unitMeasuresDl" readOnly="true">
                <query>
                    <![CDATA[select e from UnitMeasure e]]>
                </query>
            </loader>
            <fetchPlan extends="_base"/>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <settings auto="true"/>
    </facets>
    <actions>
        <action id="saveAction" type="detail_saveClose"/>
        <action id="closeAction" type="detail_close"/>
    </actions>
    <layout>
        <formLayout id="form" dataContainer="specificationDc">
          <vbox>
            <hbox id="parentAndTypeBox" alignItems="BASELINE">
                <nativeLabel text="Входит в" setFor="detalRefField" classNames="label"/>
                <textField id="detalRefField" dataContainer="specificationDc" property="parentref.detalref"
                           readOnly="true"/>
            </hbox>
            <hbox id="descriptionBox">
                <entityComboBox id="workpiecesComboBox2"
                                itemsContainer="workpiecesDc"
                                dataContainer="specificationDc" property="detalref" width="75%">
                    <actions>
                        <action id="entityClear" type="entity_clear"/>
                        <action id="entityLookup" type="entity_lookup"/>
                        <action id="entityOpen" type="entity_open"/>
                    </actions>
                </entityComboBox>
                <textField id="количествоField" property="skolko" width="10%" maxWidth="10%" label="Количество"
                           minWidth="10%"/>
                <entityComboBox id="unitMeasuresComboBox" dataContainer="specificationDc" property="unitMeasure"
                                width="15%"
                                itemsContainer="unitMeasuresDc" label="ЕдИзм"/>
            </hbox>
            <hbox id="MaterialArea" colspan="0" boxSizing="BORDER_BOX" spacing="false" alignItems="BASELINE">
                <textField dataContainer="specificationDc" property="detalref.materialref" readOnly="true"/>
                <textField dataContainer="specificationDc" property="detalref.parametrsizeref" readOnly="true"/>
                <textField dataContainer="specificationDc" property="detalref.size" width="15%" readOnly="true"/>
                <span text="мм" classNames="label ms-xs"/>
            </hbox>
            <vbox padding="false">
                <dataGrid id="operationsDataGrid" dataContainer="operationsDc" themeNames="compact"
                          width="100%"
                          minHeight="20em"
                          allRowsVisible="true" enabled="false">
                    <columns resizable="true" sortable="false">
                        <column property="typeOperationRef"/>
                        <column property="durationOp"/>
                        <column property="priceOp"/>
                        <column property="nds"/>
                        <column property="primOp"/>
                    </columns>
                </dataGrid>
            </vbox>
          </vbox>
          <hbox padding="false">
            <vbox id="photoWrapper" width="100%">
                <fileStorageUploadField
                        id="PhotoStorageUpload" dataContainer="specificationDc"
                        fileNameVisible="true"
                        property="detalref.photoFileRef" label="Фото детали" readOnly="true"/>
                <image id="photo" text="Фото" dataContainer="specificationDc" property="detalref.photoFileRef"
                       css="object-fit: contain; "
                       width="100%"/>
            </vbox>
            <vbox id="drawWrapper" width="100%">
                <fileStorageUploadField
                        id="DrawStorageUpload" dataContainer="specificationDc"
                        fileNameVisible="true"
                        property="detalref.drawFileRef" label="Чертеж детали" readOnly="true"/>
                <image id="graph" text="Чертеж" dataContainer="specificationDc" property="detalref.drawFileRef"
                       css="object-fit: contain; "
                       width="100%"/>
            </vbox>
          </hbox>
        </formLayout>

        <hbox>
            <richTextEditor property="detalref.primDetal" label="Примечание детали" minWidth="40em"
                            themeNames="compact" dataContainer="specificationDc"/>
            <richTextEditor id="primSpecField" height="6em" property="primSpec" minWidth="40em"
                            label="Примечение сборки" themeNames="compact" dataContainer="specificationDc"/>
        </hbox>
        <hbox id="detailActions">
            <button id="saveAndCloseButton" action="saveAction"/>
            <button id="closeButton" action="closeAction"/>
        </hbox>
    </layout>
</view>
