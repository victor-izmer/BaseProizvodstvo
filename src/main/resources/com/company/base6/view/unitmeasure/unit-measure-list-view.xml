<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://unitMeasureListView.title"
      focusComponent="unitMeasuresDataGrid">
    <data>
        <collection id="unitMeasuresDc"
                    class="com.company.base6.entity.UnitMeasure">
            <fetchPlan extends="_base"/>
            <loader id="unitMeasuresDl" readOnly="true">
                <query>
                    <![CDATA[select e from UnitMeasure e]]>
                </query>
            </loader>
        </collection>
        <instance id="unitMeasureDc"
                  class="com.company.base6.entity.UnitMeasure">
            <fetchPlan extends="_base"/>
            <loader id="unitMeasureDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout padding="false">
        <formLayout id="layoutWrapper" classNames="master-detail-layout" height="100%">
            <vbox id="listLayout" height="100%">
                <genericFilter id="genericFilter"
                               dataLoader="unitMeasuresDl">
                    <properties include=".*"/>
                </genericFilter>
                <hbox id="buttonsPanel" classNames="buttons-panel">
                    <button id="createButton" action="unitMeasuresDataGrid.create"/>
                    <button id="editButton" action="unitMeasuresDataGrid.edit"/>
                    <button id="removeButton" action="unitMeasuresDataGrid.remove"/>
                    <simplePagination id="pagination" dataLoader="unitMeasuresDl"/>
                </hbox>
                <dataGrid id="unitMeasuresDataGrid"
                          width="100%"
                          minHeight="20em"
                          dataContainer="unitMeasuresDc"
                          columnReorderingAllowed="true">
                    <actions>
                        <action id="create" type="list_create"/>
                        <action id="edit" type="list_edit"/>
                        <action id="edit" type="list_edit"/>
                        <action id="remove" type="list_remove"/>
                    </actions>
                    <columns resizable="true">
                        <column property="description"/>
                    </columns>
                </dataGrid>
                <hbox id="lookupActions" visible="false">
                    <button id="selectButton" action="selectAction"/>
                    <button id="discardButton" action="discardAction"/>
                </hbox>
            </vbox>
            <vbox id="detailsLayout" height="100%">
                <formLayout id="form" dataContainer="unitMeasureDc">
                    <responsiveSteps>
                        <responsiveStep minWidth="0" columns="1"/>
                        <responsiveStep minWidth="40em" columns="2"/>
                    </responsiveSteps>
                    <textField id="descriptionField" property="description"/>
                </formLayout>
                <hbox id="detailActions">
                    <button id="saveButton" text="msg:///actions.Save" icon="CHECK" themeNames="primary"/>
                    <button id="cancelButton" text="msg:///actions.Cancel" icon="BAN"/>
                </hbox>
            </vbox>
        </formLayout>
    </layout>
</view>
